{
    "name": "htlle-da-builder",
    "image": "bytebang/htlle-da-builder:latest",
    /*"build": {
		"dockerfile": "../Diplomarbeit/da-base-template/tools/docker/Dockerfile"
	},*/
    "containerEnv": {
        "SOURCE_DIR": "/workspace/Diplomarbeit"
    },
    "mounts": [
        "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
        "source=${localWorkspaceFolder}/.vscode,target=/workspace/Diplomarbeit/.vscode,type=bind,readonly,consistency=cached"
    ],
    "workspaceFolder": "/workspace/Diplomarbeit",
    "onCreateCommand": {
        "git-setup": "git config --global --add safe.directory \"*\" && git -C /workspace config --local core.filemode false && git -C /workspace config --local core.autocrlf false && git -C /workspace config --local core.eol lf"
    },
    "customizations": {
        // Visual Studio Code
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "cSpell.words": [
                    "AHWIN",
                    "BHWIN",
                    "colour",
                    "colours"
                ],
                "cSpell.language": "en,de-de",
                "todohighlight.keywords": [
                    "\\todo"
                ],
                "PandocCiter.RootFile": "/workspace/Diplomarbeit/metadata.yaml",
                "editor.tabCompletion": "on"
            },
            "extensions": [
                "sygene.auto-correct",
                "streetsidesoftware.code-spell-checker",
                "streetsidesoftware.code-spell-checker-german",
                "mhutchie.git-graph",
                "waderyan.gitblame",
                "shaharkazaz.git-merger",
                "codezombiech.gitignore",
                "yzhang.markdown-all-in-one",
                "notzaki.pandocciter",
                "tomoki1207.pdf",
                "wayou.vscode-todo-highlight",
                "ms-vscode-remote.remote-containers"
            ]
        }
    }
}
